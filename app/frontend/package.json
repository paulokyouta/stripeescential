{
  "name": "escential-frontend",
  "version": "1.0.0",
  "private": true,
  "dependencies": {
    "@measured/puck": "^0.20.2",
    "@supabase/supabase-js": "^2.106.1",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "sonner": "^1.2.0"
  },
  "scripts": {
    "build:css": "npx tailwindcss -c tailwind.config.js -i ./src/tailwind.input.css -o ../backend/static/css/tailwind.css --minify",
    "css:watch": "npx tailwindcss -c tailwind.config.js -i ./src/tailwind.input.css -o ../backend/static/css/tailwind.css --watch",
    "dev": "npm run build:css && npx webpack serve --mode development --port 8002 --host 0.0.0.0",
    "build": "npm run build:css && node node_modules/webpack-cli/bin/cli.js --mode production",
    "start": "npm run build:css && npx webpack serve --mode development --port 8002 --host 0.0.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@babel/preset-react": "^7.23.0",
    "babel-loader": "^9.1.3",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^6.8.1",
    "dotenv": "^16.4.1",
    "process": "^0.11.10",
    "style-loader": "^3.3.3",
    "tailwindcss": "^3.4.17",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
